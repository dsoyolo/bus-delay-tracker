# Copy this file to .env and fill in your credentials

# Google Maps Platform API key
# Enable: Directions API at https://console.cloud.google.com
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# AWS credentials for SNS
# IAM permissions needed: sns:Publish, sns:CreateTopic, sns:Subscribe
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ca-central-1

# Optional: override phone number from config.yaml
# ALERT_PHONE_NUMBER=+16131234567
