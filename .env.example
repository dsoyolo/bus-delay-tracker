# AWS credentials are NOT stored here.
# Instead, use one of these approaches (in preference order):
#
# 1. IAM role (best) — attach a role to your EC2/Lambda/ECS task.
#    boto3 picks it up automatically. Nothing to configure.
#
# 2. AWS CLI profile (good for local dev) — run once:
#    aws configure
#    This writes to ~/.aws/credentials (outside this repo).
#
# 3. Environment variables (last resort) — set in your shell or systemd unit:
#    export AWS_ACCESS_KEY_ID=...
#    export AWS_SECRET_ACCESS_KEY=...

# Required: AWS region for Secrets Manager and SNS
# (only needed if not set in ~/.aws/config or instance metadata)
AWS_REGION=ca-central-1
